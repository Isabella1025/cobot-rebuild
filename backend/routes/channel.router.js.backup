const express = require('express');
const router = express.Router();
const { query, queryOne } = require('../config/database');

/**
 * @route   GET /api/channels/service/:serviceId
 * @desc    Get channels for a service (filtered by user access)
 * @access  Private
 */
router.get('/service/:serviceId', async (req, res) => {
  try {
    if (!req.session.user) {
      return res.status(401).json({
        success: false,
        error: 'Authentication required'
      });
    }

    const { serviceId } = req.params;
    const userId = req.session.user.id;
    const userRole = req.session.user.role;

    let channels;

    if (userRole === 'student') {
      // Students see: public channels + their own private channels
      channels = await query(`
        SELECT DISTINCT
          sc.id,
          sc.channel_name,
          sc.service_id,
          sc.is_private,
          sc.channel_type,
          sc.created_by,
          sc.assigned_to,
          staff.full_name as assigned_staff_name,
          creator.full_name as creator_name
        FROM service_channels sc
        LEFT JOIN users staff ON sc.assigned_to = staff.id
        LEFT JOIN users creator ON sc.created_by = creator.id
        LEFT JOIN channel_participants cp ON sc.id = cp.channel_id
        WHERE sc.service_id = ? 
          AND sc.is_active = TRUE
          AND (
            sc.is_private = FALSE 
            OR (sc.is_private = TRUE AND cp.user_id = ?)
          )
        ORDER BY sc.is_private ASC, sc.created_at ASC
      `, [serviceId, userId]);

    } else if (userRole === 'staff' || userRole === 'service_admin') {
      // Staff see: public channels + all private channels for their service
      channels = await query(`
        SELECT DISTINCT
          sc.id,
          sc.channel_name,
          sc.service_id,
          sc.is_private,
          sc.channel_type,
          sc.created_by,
          sc.assigned_to,
          student.full_name as student_name,
          creator.full_name as creator_name,
          (SELECT COUNT(*) FROM messages m WHERE m.channel_id = sc.id AND m.is_read = FALSE) as unread_count
        FROM service_channels sc
        LEFT JOIN users student ON sc.created_by = student.id
        LEFT JOIN users creator ON sc.created_by = creator.id
        WHERE sc.service_id = ? 
          AND sc.is_active = TRUE
        ORDER BY sc.is_private ASC, sc.created_at DESC
      `, [serviceId]);

    } else {
      return res.status(403).json({
        success: false,
        error: 'Access denied'
      });
    }

    res.json({
      success: true,
      data: channels
    });

  } catch (error) {
    console.error('Error fetching channels:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to fetch channels'
    });
  }
});

/**
 * @route   POST /api/channels/create-private
 * @desc    Create a new private channel with a staff member
 * @access  Student
 */
router.post('/create-private', async (req, res) => {
  try {
    if (!req.session.user) {
      return res.status(401).json({
        success: false,
        error: 'Authentication required'
      });
    }

    if (req.session.user.role !== 'student') {
      return res.status(403).json({
        success: false,
        error: 'Only students can create private channels'
      });
    }

    const { service_id, staff_id } = req.body;
    const student_id = req.session.user.id;

    // Validate inputs
    if (!service_id || !staff_id) {
      return res.status(400).json({
        success: false,
        error: 'Service and staff member are required'
      });
    }

    // Check if private channel already exists between this student and staff
    const existingChannel = await queryOne(`
      SELECT id, channel_name 
      FROM service_channels 
      WHERE service_id = ? 
        AND is_private = TRUE 
        AND created_by = ? 
        AND assigned_to = ?
    `, [service_id, student_id, staff_id]);

    if (existingChannel) {
      // Return existing channel
      return res.json({
        success: true,
        message: 'Private channel already exists',
        data: { channel_id: existingChannel.id, channel_name: existingChannel.channel_name }
      });
    }

    // Get student and staff names
    const student = await queryOne('SELECT full_name FROM users WHERE id = ?', [student_id]);
    const staff = await queryOne('SELECT full_name FROM users WHERE id = ?', [staff_id]);
    const service = await queryOne('SELECT service_name FROM services WHERE id = ?', [service_id]);

    if (!student || !staff || !service) {
      return res.status(404).json({
        success: false,
        error: 'Student, staff, or service not found'
      });
    }

    // Create private channel
    const channelName = `Private: ${student.full_name} & ${staff.full_name}`;
    
    const result = await query(`
      INSERT INTO service_channels 
        (channel_name, service_id, is_private, channel_type, created_by, assigned_to, is_active, created_at)
      VALUES (?, ?, TRUE, 'private', ?, ?, TRUE, NOW())
    `, [channelName, service_id, student_id, staff_id]);

    const channelId = result.insertId;

    // Add student as participant
    await query(`
      INSERT INTO channel_participants (channel_id, user_id, role)
      VALUES (?, ?, 'student')
    `, [channelId, student_id]);

    // Add staff as participant
    await query(`
      INSERT INTO channel_participants (channel_id, user_id, role)
      VALUES (?, ?, 'staff')
    `, [channelId, staff_id]);

    console.log(`✓ Private channel created: ${channelName} (ID: ${channelId})`);

    res.json({
      success: true,
      message: 'Private channel created',
      data: { 
        channel_id: channelId, 
        channel_name: channelName,
        service_name: service.service_name,
        staff_name: staff.full_name
      }
    });

  } catch (error) {
    console.error('Error creating private channel:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to create private channel'
    });
  }
});

/**
 * @route   GET /api/channels/:channelId/messages
 * @desc    Get messages for a channel (only if user is participant)
 * @access  Private
 */
router.get('/:channelId/messages', async (req, res) => {
  try {
    if (!req.session.user) {
      return res.status(401).json({
        success: false,
        error: 'Authentication required'
      });
    }

    const { channelId } = req.params;
    const userId = req.session.user.id;
    const userRole = req.session.user.role;

    // Check if channel is private
    const channel = await queryOne(`
      SELECT is_private, created_by, assigned_to, service_id
      FROM service_channels 
      WHERE id = ?
    `, [channelId]);

    if (!channel) {
      return res.status(404).json({
        success: false,
        error: 'Channel not found'
      });
    }

    // Check access for private channels
    if (channel.is_private) {
      // Check if user is a participant
      const isParticipant = await queryOne(`
        SELECT id FROM channel_participants 
        WHERE channel_id = ? AND user_id = ?
      `, [channelId, userId]);

      if (!isParticipant && userRole !== 'service_admin') {
        return res.status(403).json({
          success: false,
          error: 'You do not have access to this private channel'
        });
      }
    }

    // Fetch messages
    const messages = await query(`
      SELECT 
        m.*,
        u.full_name as sender_name,
        u.role as sender_role
      FROM messages m
      LEFT JOIN users u ON m.sender_id = u.id
      WHERE m.channel_id = ?
      ORDER BY m.created_at ASC
    `, [channelId]);

    res.json({
      success: true,
      data: messages
    });

  } catch (error) {
    console.error('Error fetching messages:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to fetch messages'
    });
  }
});

/**
 * @route   POST /api/channels/:channelId/join
 * @desc    Join a public channel (add as participant)
 * @access  Private
 */
router.post('/:channelId/join', async (req, res) => {
  try {
    if (!req.session.user) {
      return res.status(401).json({
        success: false,
        error: 'Authentication required'
      });
    }

    const { channelId } = req.params;
    const userId = req.session.user.id;
    const userRole = req.session.user.role;

    // Check if channel exists and is public
    const channel = await queryOne(`
      SELECT id, channel_name, is_private 
      FROM service_channels 
      WHERE id = ?
    `, [channelId]);

    if (!channel) {
      return res.status(404).json({
        success: false,
        error: 'Channel not found'
      });
    }

    if (channel.is_private) {
      return res.status(403).json({
        success: false,
        error: 'Cannot join private channels'
      });
    }

    // Add user as participant (ignore if already exists)
    await query(`
      INSERT IGNORE INTO channel_participants (channel_id, user_id, role)
      VALUES (?, ?, ?)
    `, [channelId, userId, userRole === 'student' ? 'student' : 'staff']);

    res.json({
      success: true,
      message: `Joined channel: ${channel.channel_name}`
    });

  } catch (error) {
    console.error('Error joining channel:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to join channel'
    });
  }
});

module.exports = router;
